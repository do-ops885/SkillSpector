#!/usr/bin/env python3
import json, os, time, requests, sys, subprocess
from pathlib import Path

JULES_API = "https://jules.googleapis.com/v1alpha"
HEADERS = {
    "X-Goog-Api-Key": os.environ.get("JULES_API_KEY", ""),
    "Content-Type": "application/json",
}

def build_prompt(report: dict) -> str:
    issues = report.get("issues", [])
    by_sev = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
    issues = sorted(issues, key=lambda x: by_sev.get(x["severity"], 4))

    risk = report.get("risk_assessment", {})
    lines = [
        f"SkillSpector security scan: score {risk.get('score', 'N/A')}/100 "
        f"({risk.get('severity', 'N/A')}) — {risk.get('recommendation', 'N/A')}.",
        f"{len(issues)} issue(s) found. Fix each one. Do NOT refactor unrelated code.",
        "",
    ]
    for i in issues:
        loc = i.get("location", {})
        loc_str = f"{loc.get('file', 'unknown')}:{loc.get('start_line', '?')}"
        lines += [
            f"[{i['severity']}] {i['id']} — {i.get('pattern') or i.get('category', 'Issue')}",
            f"  Location: {loc_str}",
            f"  {i.get('explanation', '')}",
            "",
        ]
    lines.append(
        "After fixing, the codebase should pass: "
        "`skillspector scan . --no-llm` with a score below 20."
    )
    return "\n".join(lines)

def trigger_jules(report_path):
    print(f"Checking Jules integration for {report_path.name}...")
    try:
        with open(report_path) as f:
            report = json.load(f)
    except Exception as e:
        print(f"Error loading {report_path}: {e}")
        return

    issues = report.get("issues", [])
    if not issues:
        print(f"Scan clean for {report_path.name} — no Jules task needed.")
        return

    if not HEADERS["X-Goog-Api-Key"]:
        print("JULES_API_KEY environment variable not set. Cannot trigger Jules API sessions.")
        return

    try:
        print(f"Attempting to trigger Jules session for {report_path.name}...")
        resp = requests.get(f"{JULES_API}/sources", headers=HEADERS)
        resp.raise_for_status()
        sources = resp.json()
    except Exception as e:
        print(f"Error fetching Jules sources: {e}")
        return

    if not sources.get("sources"):
        print("No Jules sources found. Install the Jules GitHub App on your repo first.")
        return

    repo_slug = os.environ.get("GITHUB_REPOSITORY", "")
    source_name = next(
        (s["name"] for s in sources["sources"] if repo_slug in s["name"]),
        sources["sources"][0]["name"]
    )
    print(f"Using Jules source: {source_name}")

    risk = report.get("risk_assessment", {})
    payload = {
        "title": f"[SkillSpector] Fix {risk.get('severity', 'risk')} issues (score {risk.get('score', 'N/A')}/100)",
        "prompt": build_prompt(report),
        "sourceContext": {
            "source": source_name,
            "githubRepoContext": {"startingBranch": "main"},
        },
        "automationMode": "AUTO_CREATE_PR",
    }
    try:
        session = requests.post(f"{JULES_API}/sessions", headers=HEADERS, json=payload).json()
        session_id = session["id"]
        print(f"Jules session started: {session_id}")
    except Exception as e:
        print(f"Error creating Jules session: {e}")
        return

    for i in range(30):
        time.sleep(15)
        try:
            s = requests.get(f"{JULES_API}/sessions/{session_id}", headers=HEADERS).json()
            for out in s.get("outputs", []):
                if "pullRequest" in out:
                    pr = out["pullRequest"]
                    print(f"✅ PR ready: {pr['url']}")
                    return

            activities = requests.get(
                f"{JULES_API}/sessions/{session_id}/activities?pageSize=5",
                headers=HEADERS
            ).json().get("activities", [])
            if activities:
                last = activities[-1].get("progressUpdated", {}).get("title", "…")
                print(f"[{i+1}/30] Jules status: {last}")
        except Exception as e:
            print(f"Error polling Jules session: {e}")

    print(f"Timed out waiting for Jules PR — check https://jules.google.com for status.")

def scan_repo(repo_url):
    print(f"Cloning {repo_url}...")
    base_output = Path(__file__).parent / "output"
    temp_dir = base_output / "temp_repo"

    if temp_dir.exists():
        subprocess.run(["rm", "-rf", str(temp_dir)])

    subprocess.run(["git", "clone", "--depth", "1", repo_url, str(temp_dir)], check=True)

    skills_dir = temp_dir / ".agents" / "skills"
    if not skills_dir.exists():
        print(f"No .agents/skills directory found in {repo_url}")
        return

    reports_dir = base_output / "reports"
    reports_dir.mkdir(parents=True, exist_ok=True)

    for skill_path in skills_dir.iterdir():
        if skill_path.is_dir():
            skill_name = skill_path.name
            print(f"--- Scanning {skill_name} (LLM Mode Enabled) ---")
            report_path = reports_dir / f"{skill_name}.json"

            result = subprocess.run([
                "skillspector", "scan", str(skill_path),
                "--format", "json",
                "--output", str(report_path)
            ])

            if result.returncode != 0:
                print(f"WARNING: LLM scan failed/exited with code {result.returncode} for {skill_name}.")

            if report_path.exists():
                trigger_jules(report_path)
            else:
                print(f"Error: No report generated for {skill_name}")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: scripts/scan-skills <repo_url>")
        sys.exit(1)

    scan_repo(sys.argv[1])

#!/usr/bin/env python3
import json, os, time, requests, sys, subprocess
from pathlib import Path

JULES_API = "https://jules.googleapis.com/v1alpha"
HEADERS = {
    "X-Goog-Api-Key": os.environ.get("JULES_API_KEY", ""),
    "Content-Type": "application/json",
}

def build_prompt(report: dict) -> str:
    findings = report.get("filtered_findings", [])
    by_sev = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
    findings = sorted(findings, key=lambda x: by_sev.get(x["severity"], 4))

    lines = [
        f"SkillSpector security scan: score {report.get('risk_score', 'N/A')}/100 "
        f"({report.get('risk_severity', 'N/A')}) — {report.get('risk_recommendation', 'N/A')}.",
        f"{len(findings)} issue(s) found. Fix each one. Do NOT refactor unrelated code.",
        "",
    ]
    for f in findings:
        lines += [
            f"[{f['severity']}] {f['rule_id']} — {f['message']}",
            f"  Location: {f.get('location', 'unknown')}",
            f"  {f.get('explanation', '')}",
            "",
        ]
    lines.append(
        "After fixing, the codebase should pass: "
        "`skillspector scan . --no-llm` with a score below 20."
    )
    return "\n".join(lines)

def trigger_jules(report_path):
    try:
        with open(report_path) as f:
            report = json.load(f)
    except Exception as e:
        print(f"Error loading {report_path}: {e}")
        return

    if not report.get("filtered_findings"):
        print(f"Scan clean for {report_path} — no Jules task needed.")
        return

    if not HEADERS["X-Goog-Api-Key"]:
        print("JULES_API_KEY environment variable not set. Skipping Jules trigger.")
        return

    try:
        resp = requests.get(f"{JULES_API}/sources", headers=HEADERS)
        resp.raise_for_status()
        sources = resp.json()
    except Exception as e:
        print(f"Error fetching sources: {e}")
        return

    if not sources.get("sources"):
        print("No Jules sources found. Install the Jules GitHub App on your repo first.")
        return

    repo_slug = os.environ.get("GITHUB_REPOSITORY", "")
    source_name = next(
        (s["name"] for s in sources["sources"] if repo_slug in s["name"]),
        sources["sources"][0]["name"]
    )
    print(f"Using source: {source_name} for {report_path}")

    payload = {
        "title": f"[SkillSpector] Fix {report['risk_severity']} issues (score {report['risk_score']}/100)",
        "prompt": build_prompt(report),
        "sourceContext": {
            "source": source_name,
            "githubRepoContext": {"startingBranch": "main"},
        },
        "automationMode": "AUTO_CREATE_PR",
    }
    try:
        session = requests.post(f"{JULES_API}/sessions", headers=HEADERS, json=payload).json()
        session_id = session["id"]
        print(f"Jules session started for {report_path}: {session_id}")
    except Exception as e:
        print(f"Error creating session: {e}")
        return

    for i in range(30):
        time.sleep(15)
        try:
            s = requests.get(f"{JULES_API}/sessions/{session_id}", headers=HEADERS).json()
            for out in s.get("outputs", []):
                if "pullRequest" in out:
                    pr = out["pullRequest"]
                    print(f"✅ PR ready for {report_path}: {pr['url']}")
                    return

            activities = requests.get(
                f"{JULES_API}/sessions/{session_id}/activities?pageSize=5",
                headers=HEADERS
            ).json().get("activities", [])
            if activities:
                last = activities[-1].get("progressUpdated", {}).get("title", "…")
                print(f"[{i+1}/30] {report_path} Jules: {last}")
        except Exception as e:
            print(f"Error polling session: {e}")

    print(f"Timed out for {report_path} — check https://jules.google.com for status.")

def scan_repo(repo_url):
    print(f"Cloning {repo_url}...")
    temp_dir = Path("/tmp/scan_repo")
    if temp_dir.exists():
        subprocess.run(["rm", "-rf", str(temp_dir)])

    subprocess.run(["git", "clone", "--depth", "1", repo_url, str(temp_dir)], check=True)

    skills_dir = temp_dir / ".agents" / "skills"
    if not skills_dir.exists():
        print(f"No .agents/skills directory found in {repo_url}")
        return

    reports_dir = Path("reports_llm")
    reports_dir.mkdir(exist_ok=True)

    for skill_path in skills_dir.iterdir():
        if skill_path.is_dir():
            skill_name = skill_path.name
            print(f"Scanning {skill_name} with LLM...")
            report_path = reports_dir / f"{skill_name}.json"

            # Note: We try with LLM, but if it fails (like 403), we fall back to --no-llm
            result = subprocess.run([
                "skillspector", "scan", str(skill_path),
                "--format", "json",
                "--output", str(report_path)
            ])

            if result.returncode != 0:
                print(f"Scan failed for {skill_name}, trying with --no-llm...")
                subprocess.run([
                    "skillspector", "scan", str(skill_path),
                    "--format", "json",
                    "--output", str(report_path),
                    "--no-llm"
                ])

            trigger_jules(report_path)

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: scripts/scan-skills <repo_url>")
        sys.exit(1)

    scan_repo(sys.argv[1])
